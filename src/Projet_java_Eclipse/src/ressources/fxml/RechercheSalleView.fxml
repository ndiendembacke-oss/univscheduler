<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.RechercheSalleController"
      spacing="20" style="-fx-padding: 20;"
      prefHeight="700" prefWidth="1000">

    <Label text="Recherche de salles" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    
    <!-- Options de recherche -->
    <TitledPane text="Recherche rapide" expanded="true">
        <VBox spacing="15" style="-fx-padding: 15;">
            <HBox spacing="20" alignment="CENTER_LEFT">
                <RadioButton text="Maintenant" fx:id="rechercheMaintenant" selected="true" toggleGroup="$rechercheGroupe"/>
                <RadioButton text="Date/heure spécifique" fx:id="rechercheSpecifique" toggleGroup="$rechercheGroupe"/>
                <ToggleGroup fx:id="rechercheGroupe"/>
            </HBox>
            
            <GridPane hgap="10" vgap="10">
                <!-- Champs pour recherche maintenant -->
                <Label text="Capacité minimum:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="capaciteMaintenant" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="100" text="0"/>
                
                <Label text="Équipements:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <ListView fx:id="equipementsMaintenant" GridPane.rowIndex="0" GridPane.columnIndex="3" prefHeight="80" prefWidth="200"/>
                
                <!-- Champs pour recherche spécifique -->
                <Label text="Date:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <DatePicker fx:id="dateSpecifique" GridPane.rowIndex="1" GridPane.columnIndex="1" disable="true"/>
                
                <Label text="Heure début:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <ComboBox fx:id="heureSpecifique" GridPane.rowIndex="1" GridPane.columnIndex="3" prefWidth="100" disable="true"/>
                
                <Label text="Durée (min):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="dureeSpecifique" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="100" disable="true"/>
            </GridPane>
            
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Rechercher" style="-fx-background-color: #3498db; -fx-text-fill: white;" onAction="#handleRechercher"/>
                <Button text="Réinitialiser" onAction="#handleReinitialiser"/>
            </HBox>
        </VBox>
    </TitledPane>
    
    <!-- Résultats de recherche -->
    <TitledPane text="Résultats" expanded="true" VBox.vgrow="ALWAYS">
        <VBox spacing="10" style="-fx-padding: 15;">
            <Label fx:id="resultatCountLabel" text="0 salle(s) trouvée(s)"/>
            
            <TableView fx:id="resultatsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn text="Salle" prefWidth="100"/>
                    <TableColumn text="Bâtiment" prefWidth="150"/>
                    <TableColumn text="Capacité" prefWidth="80"/>
                    <TableColumn text="Étage" prefWidth="60"/>
                    <TableColumn text="Type" prefWidth="100"/>
                    <TableColumn text="Équipements" prefWidth="200"/>
                    <TableColumn text="Disponibilité" prefWidth="100"/>
                    <TableColumn text="Actions" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </TitledPane>
</VBox>